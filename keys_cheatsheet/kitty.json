        { "keys": ["Ctrl", "Shift", "F5"],    "action": "Reload kitty config" },
        { "keys": ["Ctrl", "Shift", "u"],     "action": "Unicode character input" },
        { "keys": ["Ctrl", "Shift", "Delete"],"action": "Clear terminal" },

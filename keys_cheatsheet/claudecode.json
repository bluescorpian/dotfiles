        { "keys": ["Ctrl", "a"],    "action": "Move cursor to start of line" },
        { "keys": ["Ctrl", "e"],    "action": "Move cursor to end of line" },
        { "keys": ["Ctrl", "w"],    "action": "Delete word before cursor" },
        { "keys": ["Ctrl", "u"],    "action": "Delete to start of line" },

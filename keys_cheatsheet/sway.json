{
  "meta": {
    "title": "Sway Keybindings",
    "host": "laptop · harry-smartstation",
    "modifier_display": "Super",
    "modifier_xkb": "Mod4",
    "layout_note": "Dvorak Programmer layout (us/dvp). Workspaces use named bindings on a/o/e/u.",
    "generated": "2026-05-15"
  },
  "groups": [
    {
      "id": "apps",
      "label": "Applications",
      "color": "#89b4fa",
      "bindings": [
        { "keys": ["Super", "Return"], "action": "Open terminal", "note": "kitty" },
        { "keys": ["Super", "d"],      "action": "App launcher",   "note": "rofi -show drun" }
      ]
    },
    {
      "id": "window",
      "label": "Window",
      "color": "#74c7ec",
      "bindings": [
        { "keys": ["Super", "Shift", "q"],     "action": "Kill focused window" },
        { "keys": ["Super", "f"],              "action": "Fullscreen toggle" },
        { "keys": ["Super", "Shift", "Space"], "action": "Float toggle" },
        { "keys": ["Super", "/"],              "action": "Focus tiling / floating toggle" },
        { "keys": ["Super", "p"],              "action": "Focus parent container" },
        { "keys": ["Super", "r"],              "action": "Enter resize mode" }
      ]
    },
    {
      "id": "focus",
      "label": "Focus",
      "color": "#94e2d5",
      "bindings": [
        { "keys": ["Super", "h"], "action": "Focus left",  "note": "dvp home row" },
        { "keys": ["Super", "t"], "action": "Focus down",  "note": "dvp home row" },
        { "keys": ["Super", "n"], "action": "Focus up",    "note": "dvp home row" },
        { "keys": ["Super", "s"], "action": "Focus right", "note": "dvp home row" },
        { "keys": ["Super", "←"], "action": "Focus left" },
        { "keys": ["Super", "↓"], "action": "Focus down" },
        { "keys": ["Super", "↑"], "action": "Focus up" },
        { "keys": ["Super", "→"], "action": "Focus right" }
      ]
    },
    {
      "id": "move",
      "label": "Move",
      "color": "#a6e3a1",
      "bindings": [
        { "keys": ["Super", "Shift", "h"], "action": "Move window left",  "note": "dvp home row" },
        { "keys": ["Super", "Shift", "t"], "action": "Move window down",  "note": "dvp home row" },
        { "keys": ["Super", "Shift", "n"], "action": "Move window up",    "note": "dvp home row" },
        { "keys": ["Super", "Shift", "s"], "action": "Move window right", "note": "dvp home row" },
        { "keys": ["Super", "Shift", "←"], "action": "Move window left" },
        { "keys": ["Super", "Shift", "↓"], "action": "Move window down" },
        { "keys": ["Super", "Shift", "↑"], "action": "Move window up" },
        { "keys": ["Super", "Shift", "→"], "action": "Move window right" }
      ]
    },
    {
      "id": "layout",
      "label": "Layout",
      "color": "#cba6f7",
      "bindings": [
        { "keys": ["Super", "b"],          "action": "Split horizontal" },
        { "keys": ["Super", "v"],          "action": "Split vertical" },
        { "keys": ["Super", "Shift", "w"], "action": "Stacking layout", "note": "moved off Super+s (now focus right)" },
        { "keys": ["Super", "w"],          "action": "Tabbed layout" },
        { "keys": ["Super", "x"],          "action": "Toggle split layout" }
      ]
    },
    {
      "id": "resize",
      "label": "Resize Mode",
      "color": "#f9e2af",
      "bindings": [
        { "keys": ["←"],      "action": "Shrink width",       "note": "after Super+r to enter mode" },
        { "keys": ["↓"],      "action": "Grow height",        "note": "after Super+r to enter mode" },
        { "keys": ["↑"],      "action": "Shrink height",      "note": "after Super+r to enter mode" },
        { "keys": ["→"],      "action": "Grow width",         "note": "after Super+r to enter mode" },
        { "keys": ["Return"], "action": "Exit resize mode" },
        { "keys": ["Escape"], "action": "Exit resize mode" }
      ]
    },
    {
      "id": "workspaces",
      "label": "Workspaces",
      "color": "#b4befe",
      "bindings": [
        { "keys": ["Super", "a"],              "action": "Switch to workspace web" },
        { "keys": ["Super", "o"],              "action": "Switch to workspace notes" },
        { "keys": ["Super", "e"],              "action": "Switch to workspace code" },
        { "keys": ["Super", "u"],              "action": "Switch to workspace term" },
        { "keys": ["Super", "Shift", "a"],    "action": "Move container to workspace web" },
        { "keys": ["Super", "Shift", "o"],    "action": "Move container to workspace notes" },
        { "keys": ["Super", "Shift", "e"],    "action": "Move container to workspace code" },
        { "keys": ["Super", "Shift", "u"],    "action": "Move container to workspace term" },
        { "keys": ["Super", "Tab"],            "action": "Previous workspace" },
        { "keys": ["Super", "Shift", "Tab"],  "action": "Workspace picker", "note": "type a new name to create it" },
        { "keys": ["Super", "Ctrl", "←"],      "action": "Previous workspace on output" },
        { "keys": ["Super", "Ctrl", "→"],      "action": "Next workspace on output" },
        { "keys": ["Super", "Ctrl", "Shift", "←"], "action": "Move container to previous workspace on output and switch" },
        { "keys": ["Super", "Ctrl", "Shift", "→"], "action": "Move container to next workspace on output and switch" }
      ]
    },
    {
      "id": "switchers",
      "label": "Switchers",
      "color": "#f5c2e7",
      "bindings": [
        { "keys": ["Super", "`"],          "action": "Window switcher",              "note": "rofi -show window" },
        { "keys": ["Super", "Shift", "v"], "action": "Clipboard history",            "note": "cliphist + rofi" }
      ]
    },
    {
      "id": "output",
      "label": "Output",
      "color": "#89dceb",
      "bindings": [
        { "keys": ["Super", "Space"],       "action": "Move workspace to next output" }
      ]
    },
    {
      "id": "system",
      "label": "System",
      "color": "#f38ba8",
      "bindings": [
        { "keys": ["Print"],               "action": "Screenshot region → clipboard", "note": "grim + slurp + wl-copy" },
        { "keys": ["Super", "l"],          "action": "Lock screen",                  "note": "swaylock" },
        { "keys": ["Super", "Shift", "c"], "action": "Reload Sway config" },
        { "keys": ["Super", "Shift", "End"], "action": "Exit Sway" }
      ]
    },
    {
      "id": "media",
      "label": "Media & Hardware",
      "color": "#fab387",
      "bindings": [
        { "keys": ["🔊 Vol+"],       "action": "Volume up 5%" },
        { "keys": ["🔉 Vol−"],       "action": "Volume down 5%" },
        { "keys": ["🔇 Mute"],       "action": "Toggle audio mute" },
        { "keys": ["🎤 Mic Mute"],   "action": "Toggle microphone mute" },
        { "keys": ["☀ Bright+"],     "action": "Brightness up 5%" },
        { "keys": ["🌙 Bright−"],    "action": "Brightness down 5%" },
        { "keys": ["⏯ Play/Pause"],  "action": "Play / pause" },
        { "keys": ["⏭ Next"],        "action": "Skip to next track" },
        { "keys": ["⏮ Prev"],        "action": "Go to previous track" }
      ]
    }
  ]
}

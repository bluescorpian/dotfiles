      "color": "#f9e2af",
      "bindings": [
        { "keys": ["/help"],        "action": "Show help and available commands" },
        { "keys": ["/clear"],       "action": "Clear conversation history" },
        { "keys": ["/compact"],     "action": "Compact conversation to save context" },
